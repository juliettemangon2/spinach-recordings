{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/resources/layout,_N_T_/resources/[slug]/layout,_N_T_/resources/[slug]/page,_N_T_/resources/reputation"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/resources/$d$slug/__PAGE__",
    "/resources/$d$slug",
    "/resources",
    "/_index",
    "/_head"
  ]
}